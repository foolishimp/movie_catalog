# Copy to .env and fill in your values

# Postgres (matches docker-compose defaults)
DATABASE_URL=postgresql://catalog:catalog@localhost:5432/media_catalog

# TMDb API key — get one free at https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# Directories to scan (colon-separated)
MEDIA_DIRS=/path/to/movies:/path/to/series:/another/path

# Video file extensions to match
VIDEO_EXTENSIONS=.mkv,.mp4,.avi,.m4v,.wmv,.flv,.mov,.ts,.webm,.mpg,.mpeg,.divx,.ogm,.iso,.img
